@model string
@{
    Layout = null;
    ViewData["Title"] = "Contraseña restablecida";
    var redirectUrl = string.IsNullOrWhiteSpace(Model) ? "/" : Model;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        html, body {
            margin: 0;
            padding: 0;
            height: 100%;
        }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background-color: #f0f2f5;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow-x: hidden;
        }

        .reset-success-card {
            background: #ffffff;
            padding: 50px 40px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            max-width: 400px;
            width: 90%;
            text-align: center;
            box-sizing: border-box;
        }

        .success-icon {
            margin-bottom: 20px;
        }

        .reset-success-card h2 {
            color: #1a1a1a;
            font-weight: 700;
            margin: 0 0 15px 0;
        }

        .reset-success-card p {
            color: #666;
            line-height: 1.6;
            margin-bottom: 30px;
        }

        .btn-primary-custom {
            display: inline-block;
            width: 100%;
            background-color: #5d59d6;
            color: white !important;
            text-decoration: none;
            padding: 15px 0;
            border-radius: 30px;
            font-weight: bold;
            font-size: 13px;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 12px rgba(93, 89, 214, 0.3);
            text-transform: uppercase;
        }

        .btn-primary-custom:hover {
            background-color: #4a46b5;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(93, 89, 214, 0.4);
        }
    </style>
</head>
<body>
    <div class="reset-success-card">
        <div class="success-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="#5d59d6" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
            </svg>
        </div>

        <h2>¡Todo listo!</h2>
        <p>Tu contraseña ha sido restablecida con éxito. Ahora puedes volver a entrar a tu cuenta.</p>

        <div class="action-area">
            <a class="btn-primary-custom" href="@redirectUrl">IR AL INICIO DE SESIÓN</a>
        </div>
    </div>
</body>
</html>
